{
    "name": "oceanmoon/collections",
    "description": "Type-safe PHP collections: Sequence (ordered list), Dictionary (any-type keys), Set (unique values), with runtime type validation.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "collections",
        "typed",
        "sequence",
        "dictionary",
        "set",
        "list",
        "array",
        "generics",
        "type-safe"
    ],
    "authors": [
        {
            "name": "Shaun Moss",
            "email": "shaun@oceanmoon.software"
        }
    ],
    "homepage": "https://github.com/mossy2100/PHP-Collections",
    "support": {
        "issues": "https://github.com/mossy2100/PHP-Collections/issues",
        "source": "https://github.com/mossy2100/PHP-Collections"
    },
    "require": {
        "php": "^8.4",
        "oceanmoon/core": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0 || ^12.0",
        "squizlabs/php_codesniffer": "^4.0",
        "phpstan/phpstan": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "oceanmoon/coding-standard": "^2.0"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "OceanMoon\\Collections\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OceanMoon\\Collections\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "fix": "vendor/bin/phpcbf -vp",
        "check": "vendor/bin/phpcs -s",
        "report": "vendor/bin/phpcs -q --report=summary",
        "analyze": "scripts/analyze",
        "test": "php -d xdebug.mode=coverage vendor/bin/phpunit --coverage-html build/coverage --coverage-clover build/logs/clover.xml --do-not-cache-result",
        "coverage": "php scripts/coverage-check.php",
        "quality": [
            "@fix",
            "@check",
            "@analyze",
            "@test",
            "@coverage"
        ]
    }
}
